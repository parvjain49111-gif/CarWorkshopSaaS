// Prisma schema for WorkshopOps
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workshop {
  id        String   @id @default(uuid())
  name      String
  gstNumber String?
  createdAt DateTime @default(now())
  branches  Branch[]
  users     User[]
}

model Branch {
  id         String   @id @default(uuid())
  name       String
  workshop   Workshop @relation(fields: [workshopId], references: [id])
  workshopId String
  createdAt  DateTime @default(now())
}

model User {
  id           String    @id @default(uuid())
  workshop     Workshop? @relation(fields: [workshopId], references: [id])
  workshopId   String?
  email        String    @unique
  name         String
  phone        String?
  passwordHash String
  role         UserRole  @default(OWNER)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
}

enum UserRole {
  OWNER
  MANAGER
  SERVICE_ADVISOR
  MECHANIC
  ACCOUNTANT
}

model Customer {
  id           String   @id @default(uuid())
  workshop     Workshop @relation(fields: [workshopId], references: [id])
  workshopId   String
  name         String
  phone        String
  altPhone     String?
  email        String?
  address      String?
  gstNumber    String?
  loyaltyScore Int      @default(0)
  createdAt    DateTime @default(now())
  vehicles     Vehicle[]
}

model Vehicle {
  id                String   @id @default(uuid())
  customer          Customer @relation(fields: [customerId], references: [id])
  customerId        String
  registration      String   @unique
  model             String?
  company           String?
  fuelType          String?
  engineNumber      String?
  chassisNumber     String?
  insuranceExpiry   DateTime?
  pucExpiry         DateTime?
  rcExpiry          DateTime?
  createdAt         DateTime @default(now())
  jobCards          JobCard[]
}

model JobCard {
  id               String   @id @default(uuid())
  jobCardNumber    String   @unique
  workshop         Workshop @relation(fields: [workshopId], references: [id])
  workshopId       String
  branchId         String?
  customer         Customer @relation(fields: [customerId], references: [id])
  customerId       String
  vehicle          Vehicle  @relation(fields: [vehicleId], references: [id])
  vehicleId        String
  registration     String
  vin              String?
  odometer         Int?
  assignedAdvisor  String?
  assignedMechanic String?
  serviceType      String?
  complaint        String
  technicianNotes  String?
  labourCharges    Float   @default(0)
  gstPercent       Float?  
  discountAmount   Float?  @default(0)
  totalAmount      Float?  @default(0)
  paymentStatus    String  @default("pending")
  vehicleStatus    String  @default("vehicle_received")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  statuses         JobStatusHistory[]
  parts            JobPartUsage[]
}

model JobStatusHistory {
  id        String   @id @default(uuid())
  job       JobCard  @relation(fields: [jobId], references: [id])
  jobId     String
  status    String
  changedBy String?
  note      String?
  createdAt DateTime @default(now())
}

model JobPartUsage {
  id         String   @id @default(uuid())
  job        JobCard  @relation(fields: [jobId], references: [id])
  jobId      String
  name       String
  quantity   Int      @default(1)
  unitPrice  Float?   
  gstPercent Float?   
  status     String   @default("pending")
  createdAt  DateTime @default(now())
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  revoked    Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model Part {
  id           String   @id @default(uuid())
  workshop     Workshop @relation(fields: [workshopId], references: [id])
  workshopId   String
  partNumber   String   @unique
  name         String
  category     String?
  brand        String?
  supplier     String?
  purchasePrice Float?
  mrp          Float?
  gstPercent   Float?
  quantity     Int      @default(0)
  reserved     Int      @default(0)
  minimumStock Int?    
  warehouse    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Invoice {
  id           String   @id @default(uuid())
  invoiceNumber String  @unique
  workshop     Workshop @relation(fields: [workshopId], references: [id])
  workshopId   String
  customer     Customer @relation(fields: [customerId], references: [id])
  customerId   String
  jobCardId    String?
  issueDate    DateTime @default(now())
  totalAmount  Float?   @default(0)
  status       String   @default("draft")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
